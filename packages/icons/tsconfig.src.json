{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2022"],
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.spec.*"]
}
