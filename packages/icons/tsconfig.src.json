{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2019"],
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.spec.*", "src/**/*.stories.*", "src/story-helpers.ts"]
}
